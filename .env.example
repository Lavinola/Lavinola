# TMDB: https://www.themoviedb.org/settings/api (API gratis, no comercial hasta pedir autorización)
EXPO_PUBLIC_TMDB_API_KEY=tu_tmdb_api_key
EXPO_PUBLIC_TMDB_READ_TOKEN=tu_tmdb_read_access_token

# Supabase: Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://tuproyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key

# Giphy (GIFs en comentarios, no se pueden subir fotos propias): https://developers.giphy.com/
# Reemplaza a Tenor, que Google discontinuó (dejó de andar el 30/06/2026).
EXPO_PUBLIC_GIPHY_API_KEY=tu_giphy_api_key
